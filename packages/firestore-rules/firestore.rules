rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboards are read-only for clients. Writes are API-gated through Cloud Functions.
    match /modulo_leaderboard/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Daily leaderboard buckets are read-only for clients.
    match /modulo_daily_leaderboard/{challengeId}/scores/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Weekly leaderboard buckets are read-only for clients.
    match /modulo_weekly_leaderboard/{weekId}/scores/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Purchases collection - only the user can read/write their own purchases
    match /purchases/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles - users can read/write their own profile
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Game statistics - users can read/write their own stats
    match /game_stats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}